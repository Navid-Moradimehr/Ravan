FROM python:3.11-slim

WORKDIR /app

COPY services ./services
COPY config ./config

RUN pip install --no-cache-dir fastapi uvicorn httpx pydantic psycopg2-binary

ENV PYTHONPATH=/app

EXPOSE 8020

CMD ["python", "-m", "uvicorn", "services.api_service.main:app", "--host", "0.0.0.0", "--port", "8020"]
