FROM python:3.11-slim

WORKDIR /app

COPY services/api_service/main.py ./api_service/
COPY services/historian/client.py ./historian/
COPY services/assets/model.py ./assets/
COPY services/scenarios/engine.py ./scenarios/
COPY services/common/ ./common/
COPY config/ ./config/

RUN pip install --no-cache-dir fastapi uvicorn httpx pydantic psycopg2-binary

ENV PYTHONPATH=/app

EXPOSE 8020

CMD ["python", "-m", "uvicorn", "api_service.main:app", "--host", "0.0.0.0", "--port", "8020"]
