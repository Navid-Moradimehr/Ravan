# Ravan production Compose configuration. Copy to .env and replace every
# CHANGE_ME value before enabling production traffic. Do not commit .env.
PROJECT_NAME=ravan
DATASTREAM_CORS_ALLOW_ORIGINS=https://ravan.example.internal
GRAFANA_PUBLIC_URL=https://grafana.example.internal
POSTGRES_DB=ravan_connect
POSTGRES_USER=ravan
POSTGRES_PASSWORD=CHANGE_ME_STRONG_CONNECT_DATABASE_PASSWORD
TIMESCALE_DB=ravan
TIMESCALE_USER=ravan
TIMESCALE_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
LAKEHOUSE_CATALOG_URI=postgresql+psycopg2://ravan:CHANGE_ME_STRONG_DATABASE_PASSWORD@timescaledb:5432/ravan
MINIO_ROOT_USER=ravan
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_OBJECT_STORE_PASSWORD
GF_SECURITY_ADMIN_USER=ravan-admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD
LAKEHOUSE_S3_ACCESS_KEY=CHANGE_ME
LAKEHOUSE_S3_SECRET_KEY=CHANGE_ME
LLM_PROVIDER=openai_compat
LLM_ENDPOINT_URL=http://model-gateway.internal/v1
LLM_API_KEY=CHANGE_ME_OR_INJECT_FROM_SECRET_MANAGER
LLM_MODEL_ID=operator-selected-model
LLM_ALLOW_FALLBACK=false
DATASTREAM_UPDATE_CHECK_ENABLED=false
DATASTREAM_UPDATE_MANIFEST_URL=
