{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ravan Operator",
  "version": "1.0.0-1",
  "identifier": "com.ravan.platform.operator",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ravan Operator",
        "width": 1180,
        "height": 760,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' http: https: ws: wss: data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["nsis", "msi", "dmg", "appimage", "deb", "rpm"],
    "category": "Utility",
    "shortDescription": "Ravan Site Server operator shell",
    "longDescription": "A lightweight native window for connecting to a customer-managed Ravan Site Server."
  }
}
