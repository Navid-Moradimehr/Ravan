PROJECT_NAME=local-stream-engine

REDPANDA_BROKERS=localhost:19092
REDPANDA_SCHEMA_REGISTRY_URL=http://localhost:18081

POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=stream_engine
POSTGRES_USER=stream
POSTGRES_PASSWORD=stream

IOT_TOPIC=iot.raw
PROCESSED_TOPIC=iot.processed
AI_ENRICHED_TOPIC=iot.ai_enriched
CDC_TOPIC_PREFIX=dbserver1.public

MOCK_RATE_PER_SECOND=100
MOCK_DEVICE_COUNT=50

OPENAI_BASE_URL=http://172.17.0.1:1234/v1
OPENAI_API_KEY=lm-studio
OPENAI_MODEL=openai/gpt-oss-20B
# Provider-neutral AI gateway. Named cloud providers use their native API or
# OpenAI-compatible contract; override the endpoint for regional/private gateways.
LLM_PROVIDER=openai_compat
LLM_ENDPOINT_URL=http://172.17.0.1:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL_ID=openai/gpt-oss-20B
LLM_MAX_OUTPUT_TOKENS=2048
LLM_LOCAL_ONLY=false
LLM_BATCH_SECONDS=5
LLM_MAX_BATCH_SIZE=100
LLM_TIMEOUT_SECONDS=8
AI_REPORT_QUEUE_SIZE=16
AI_REPORT_MAX_IN_FLIGHT=1
LLM_ALLOW_FALLBACK=true

# Optional, read-only GitHub/internal release notification. Keep disabled for
# air-gapped sites. This never downloads or installs an artifact.
DATASTREAM_UPDATE_CHECK_ENABLED=false
DATASTREAM_UPDATE_MANIFEST_URL=

# Persistent API metadata registries (Compose maps these to /data).
MODEL_REGISTRY_PATH=.datastream/model-registry.json
PROMPT_REGISTRY_PATH=.datastream/prompt-registry.json
SCHEMA_REGISTRY_PATH=.datastream/schema-registry.json
DATASET_CATALOG_PATH=.datastream/dataset-catalog.json

AI_GATEWAY_HOST=0.0.0.0
AI_GATEWAY_PORT=8080

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
